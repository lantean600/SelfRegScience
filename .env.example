# Local development (SQLite file) — 优先于系统环境变量里的 libsql://
DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-in-production"

# 若 Windows/IDE 全局设置了 DATABASE_URL=libsql:// 会导致本地误连 Turso；
# 保持上面 file: 即可。要用本地连 Turso 时：USE_TURSO_LOCAL=1 并配置下方两项。

# Turso / production (libSQL)
# DATABASE_URL="libsql://selfregscience-lantean.aws-ap-northeast-1.turso.io"
# DATABASE_AUTH_TOKEN=""   # 仅粘贴 Turso JWT，不要中文说明
