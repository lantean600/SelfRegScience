{
  "name": "self-reg-science",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:d1:generate": "node scripts/generate-d1-migration.mjs",
    "db:d1:apply:local": "node scripts/apply-d1-migration.mjs local",
    "db:d1:apply:remote": "node scripts/apply-d1-migration.mjs remote",
    "db:seed": "tsx prisma/seed.ts",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:secret:session": "node scripts/put-session-secret.mjs",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "test": "vitest run && node scripts/check-no-inline-style.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xyflow/react": "^12.6.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "wrangler": "^4.94.0"
  }
}
